# Optional provider settings. The app runs without these by using deterministic fallback.
LLM_PROVIDER=
LLM_MODEL=gpt-5
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Local deterministic modes:
# LLM_PROVIDER=template
# LLM_PROVIDER=mock

# Optional bounded LLM profile enrichment. Defaults off for reproducible evals.
BLUECHIP_PROFILE_ENHANCER=false

# OpenRouter example:
# LLM_PROVIDER=openrouter
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# DeepSeek direct API example:
# LLM_PROVIDER=deepseek
# DEEPSEEK_MODEL=deepseek-v4-flash

# Runtime settings
APP_ENV=local
LOG_LEVEL=INFO

# Optional Task A artifacts
TASK_A_MODEL_PATH=data/processed/all_categories/task_a_model_rmse.json
TASK_A_STATS_PATH=data/processed/all_categories/task_a_rating_stats.json
TASK_A_SERVING_POLICY=data/processed/all_categories/task_a_serving_policy.json

# Optional Task B artifacts
TASK_B_RETRIEVAL_INDEX=data/processed/all_categories/collaborative_retrieval.json
TASK_B_EVIDENCE_GRAPH_INDEX=data/processed/all_categories/evidence_graph_retrieval.json
TASK_B_RANKER_WEIGHTS=

# Optional SQLite feature store backend.
# Build with: make sqlite-feature-store PROCESSED_DIR=data/processed/all_categories
BLUECHIP_FEATURE_STORE_SQLITE=
